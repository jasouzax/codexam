interface ProblemScore {
  maxScore: number;
  currentScore: number;
  achieveTime: Date | null;
}

interface Participant {
  name: string;
  lang: string;
  accepted: boolean;
  problemScores: ProblemScore[];
  totalMax: number;
  totalAchieveTime: Date | null;
}

const participants = new Map<string, Participant>();
const connections = new Map<WebSocket, string>(); // ws to name
const pending: { name: string; lang: string; ws: WebSocket }[] = [];
let processing = false;

async function processPending() {
  if (processing || pending.length === 0) return;
  processing = true;
  while (pending.length > 0) {
    const app = pending.shift()!;
    console.log(`New application: ${app.name} (${app.lang}). Accept? (y/n)`);
    for await (const line of readLines(Deno.stdin)) {
      const trimmed = line.trim().toLowerCase();
      if (trimmed === 'y') {
        if (participants.has(app.name)) {
          app.ws.send(JSON.stringify({ type: 'declined', msg: 'Name already taken' }));
          break;
        }
        participants.set(app.name, {
          name: app.name,
          lang: app.lang,
          accepted: true,
          problemScores: challenges.map(() => ({ maxScore: 0, currentScore: 0, achieveTime: null })),
          totalMax: 0,
          totalAchieveTime: null,
        });
        connections.set(app.ws, app.name);
        app.ws.send(JSON.stringify({ type: 'accepted' }));
        break;
      } else if (trimmed === 'n') {
        app.ws.send(JSON.stringify({ type: 'declined' }));
        break;
      } else {
        console.log('Invalid input. Accept? (y/n)');
      }
    }
  }
  processing = false;
}

async function handleCLI() {
  for await (const line of readLines(Deno.stdin)) {
    const cmd = line.trim().toLowerCase();
    if (cmd === 'start' && phase === 'registration') {
      phase = 'ongoing';
      startTime = new Date();
      endTime = new Date(startTime.getTime() + duration);
      broadcast({ type: 'phase', phase, startTime: startTime.getTime(), duration });
      console.log('Competition started.');
    } else if (cmd === 'end' && phase === 'ongoing') {
      phase = 'ended';
      broadcast({ type: 'phase', phase });
      console.log('Competition ended.');
    }
  }
}

function broadcast(msg: object) {
  const str = JSON.stringify(msg);
  for (const ws of connections.keys()) {
    ws.send(str);
  }
}

setInterval(() => {
  if (phase === 'ongoing' && endTime && new Date() > endTime) {
    phase = 'ended';
    broadcast({ type: 'phase', phase });
    console.log('Competition time up.');
  }
}, 1000);

async function runCode(lang: string, code: string, input: string): Promise<{ output: string; error?: string }> {
  let output = '';
  let error = '';
  let tempDir = '';
  try {
    tempDir = await Deno.makeTempDir();
    const encoder = new TextEncoder();
    const decoder = new TextDecoder();

    let cmd: string[];
    let file: string;
    let execCmd: string[];

    switch (lang) {
      case 'Python':
        file = `${tempDir}/main.py`;
        await Deno.writeTextFile(file, code);
        cmd = ['python', file];
        break;
      case 'Java':
        file = `${tempDir}/Main.java`;
        await Deno.writeTextFile(file, code);
        const javacProc = await Deno.run({ cmd: ['javac', 'Main.java'], cwd: tempDir, stderr: 'piped' });
        const javacStatus = await javacProc.status();
        if (!javacStatus.success) {
          error = decoder.decode(await javacProc.stderrOutput());
          return { output, error };
        }
        cmd = ['java', '-cp', tempDir, 'Main'];
        break;
      case 'C++':
        file = `${tempDir}/main.cpp`;
        await Deno.writeTextFile(file, code);
        const gppProc = await Deno.run({ cmd: ['g++', 'main.cpp', '-o', 'main'], cwd: tempDir, stderr: 'piped' });
        const gppStatus = await gppProc.status();
        if (!gppStatus.success) {
          error = decoder.decode(await gppProc.stderrOutput());
          return { output, error };
        }
        cmd = [`${tempDir}/main`];
        break;
      case 'C':
        file = `${tempDir}/main.c`;
        await Deno.writeTextFile(file, code);
        const gccProc = await Deno.run({ cmd: ['gcc', 'main.c', '-o', 'main'], cwd: tempDir, stderr: 'piped' });
        const gccStatus = await gccProc.status();
        if (!gccStatus.success) {
          error = decoder.decode(await gccProc.stderrOutput());
          return { output, error };
        }
        cmd = [`${tempDir}/main`];
        break;
      default:
        error = 'Unsupported language';
        return { output, error };
    }

    const proc = await Deno.run({
      cmd,
      stdin: 'piped',
      stdout: 'piped',
      stderr: 'piped',
      cwd: tempDir,
    });

    await proc.stdin!.write(encoder.encode(input));
    await proc.stdin!.close();

    const [outRaw, errRaw, status] = await Promise.all([
      proc.output(),
      proc.stderrOutput(),
      proc.status(),
    ]);

    if (!status.success) {
      error = decoder.decode(errRaw);
    } else {
      output = decoder.decode(outRaw);
    }
  } catch (e) {
    error = e.message;
  } finally {
    if (tempDir) await Deno.remove(tempDir, { recursive: true });
  }
  return { output, error };
}

function diffHtml(expected: string, actual: string): string {
  console.log('DIFF', expected, actual);
  const expLines = expected.split('\n');
  const actLines = actual.split('\n');
  let html = '';
  const maxLen = Math.max(expLines.length, actLines.length);
  for (let i = 0; i < maxLen; i++) {
    const exp = expLines[i] || '';
    const act = actLines[i] || '';
    if (exp === act) {
      html += `${exp}<br>`;
    } else {
      let lineHtml = '';
      const lineMax = Math.max(exp.length, act.length);
      for (let j = 0; j < lineMax; j++) {
        if (exp[j] === act[j]) {
          lineHtml += act[j] || '';
        } else {
          lineHtml += `<span style="background-color:red;color:white;">${act[j] || ' '}</span>`;
        }
      }
      html += `${lineHtml}<br>`;
    }
  }
  return `<pre style="margin:0;">${html}</pre>`;
}

function handleMessage(ws: WebSocket, data: string) {
  const msg = JSON.parse(data);
  const name = connections.get(ws);
  switch (msg.type) {
    case 'apply':
      if (phase !== 'registration') {
        ws.send(JSON.stringify({ type: 'error', msg: 'Registration closed' }));
        return;
      }
      pending.push({ name: msg.name, lang: msg.lang, ws });
      processPending();
      break;
    case 'reconnect':
      if (participants.has(msg.name) && participants.get(msg.name)!.accepted) {
        connections.set(ws, msg.name);
        ws.send(JSON.stringify({
          type: 'status',
          phase,
          accepted: true,
          lang: participants.get(msg.name)!.lang,
          startTime: startTime?.getTime(),
          duration,
        }));
      } else {
        ws.send(JSON.stringify({ type: 'not_registered' }));
      }
      break;
    case 'test':
      if (!name || phase !== 'ongoing') return;
      (async () => {
        const p = participants.get(name)!;
        const ch = challenges[msg.problem];
        const tc = ch.testcases[msg.case];
        const { output, error } = await runCode(p.lang, msg.code, tc.input);
        const actual = (output || '').trim();
        const exp = tc.expected.trim();
        const passed = !error && actual === exp;
        const diff = passed ? '' : diffHtml(exp, actual || '');
        ws.send(JSON.stringify({
          type: 'test_result',
          problem: msg.problem,
          testcase: msg.case,
          passed,
          diff,
          error,
        }));
      })();
      break;
    case 'submit':
      if (!name || phase !== 'ongoing') return;
      (async () => {
        const p = participants.get(name)!;
        const ch = challenges[msg.problem];
        const passedArr: boolean[] = [];
        const diffs: string[] = [];
        let currentScore = 0;
        for (const tc of ch.testcases) {
          const { output, error } = await runCode(p.lang, msg.code, tc.input);
          const actual = (output || '').trim();
          const exp = tc.expected.trim();
          const passed = !error && actual === exp;
          passedArr.push(passed);
          diffs.push(passed ? '' : diffHtml(exp, actual || ''));
          if (passed) currentScore += tc.points;
        }
        const ps = p.problemScores[msg.problem];
        ps.currentScore = currentScore;
        if (currentScore > ps.maxScore) {
          ps.maxScore = currentScore;
          ps.achieveTime = new Date();
          let newTotal = 0;
          for (const score of p.problemScores) {
            newTotal += score.maxScore;
          }
          if (newTotal > p.totalMax) {
            p.totalMax = newTotal;
            p.totalAchieveTime = new Date();
          }
        }
        ws.send(JSON.stringify({
          type: 'submit_result',
          problem: msg.problem,
          passed: passedArr,
          diffs,
          currentScore: ps.currentScore,
          maxScore: ps.maxScore,
        }));
      })();
      break;
    case 'get_leaderboard':
      const lb: Record<string, { name: string; points: number }[]> = {};
      ['Python', 'Java', 'C++', 'C'].forEach(lang => {
        lb[lang] = Array.from(participants.values())
          .filter(p => p.lang === lang && p.accepted)
          .sort((a, b) => b.totalMax - a.totalMax || (a.totalAchieveTime?.getTime() ?? 0) - (b.totalAchieveTime?.getTime() ?? 0))
          .map(p => ({ name: p.name, points: p.totalMax }));
      });
      ws.send(JSON.stringify({ type: 'leaderboard', data: lb }));
      break;
  }
}

