                applyBtn.style.display = '';
                waitingText.style.display = 'none';
                arenaElements.forEach(el => el.style.display = 'none');
              }
            } else if (phase === 'ongoing') {
              if (accepted) {
                home.style.display = 'none';
              } else {
                home.style.display = 'block';
                nameInput.style.display = 'none';
                langSelect.style.display = 'none';
                applyBtn.style.display = 'none';
                waitingText.textContent = 'Competition ongoing. You are not registered.';
                waitingText.style.display = 'block';
              }
              startTimer();
            } else if (phase === 'ended') {
              over.style.display = 'block';
              arenaElements.forEach(el => el.style.display = 'none');
              timeDiv.textContent = 'Competition Over';
              ws.send(JSON.stringify({ type: 'get_leaderboard' }));
            }
          }

          function startTimer() {
            if (timerInterval) clearInterval(timerInterval);
            timerInterval = setInterval(() => {
              if (startTime && duration) {
                const now = Date.now();
                const end = startTime + duration;
                let remaining = end - now;
                if (remaining <= 0) {
                  remaining = 0;
                  clearInterval(timerInterval);
                  phase = 'ended';
                  updateUI();
                }
                const hours = Math.floor(remaining / 3600000);
                const mins = Math.floor((remaining % 3600000) / 60000);
                const secs = Math.floor((remaining % 60000) / 1000);
                timeDiv.textContent = \`\${hours.toString().padStart(2, '0')}:\${mins.toString().padStart(2, '0')}:\${secs.toString().padStart(2, '0')} left\`;
              }
            }, 1000);
          }

          function selectProblem(index) {
            currentProblem = index;
            info.innerHTML = challenges[index].statement;
            code.value = localStorage.getItem(\`code_\${index}\`) || '';
            updateCases();
            updateMatch();
            tabs.querySelectorAll('button').forEach((b, i) => b.style.backgroundColor = i === index ? '#990000' : 'red');
          }

          function updateCases() {
            casesDiv.innerHTML = '';
            for (let i = 0; i < challenges[currentProblem].numTestcases; i++) {
              const btn = document.createElement('button');
              btn.textContent = i.toString().padStart(2, '0');
              if (passed[currentProblem][i] === true) btn.classList.add('passed');
              else if (passed[currentProblem][i] === false) btn.classList.add('failed');
              btn.onclick = () => {
                currentCase = i;
                updateMatch();
              };
              casesDiv.appendChild(btn);
            }
          }

          function updateMatch() {
            match.innerHTML = diffs[currentProblem][currentCase] || '';
          }

          function populateLeaderboard(data) {
            const langs = { Python: 'lb-python', Java: 'lb-java', 'C++': 'lb-cpp', C: 'lb-c' };
            for (const [lang, tableId] of Object.entries(langs)) {
              const table = document.getElementById(tableId);
              table.innerHTML = '<tr><th>Name</th><th>Points</th></tr>';
              (data[lang] || []).forEach(entry => {
                const tr = document.createElement('tr');
                tr.innerHTML = \`<td>\${entry.name}</td><td>\${entry.points}</td>\`;
                table.appendChild(tr);
              });
            }
          }

          ws.onmessage = (e) => {
            const msg = JSON.parse(e.data);
            switch (msg.type) {
              case 'status':
              case 'phase':
                phase = msg.phase;
                startTime = msg.startTime ? msg.startTime : startTime;
                duration = msg.duration ? msg.duration : duration;
                if (msg.accepted) {
                  accepted = true;
                  lang = msg.lang;
                }
                updateUI();
                break;
              case 'accepted':
                accepted = true;
                name = nameInput.value;
                lang = langSelect.value;
                localStorage.setItem('name', name);
                localStorage.setItem('lang', lang);
                updateUI();
                break;
              case 'declined':
                alert('Application declined.');
                break;
              case 'test_result':
                passed[msg.problem][msg.testcase] = msg.passed;
                diffs[msg.problem][msg.testcase] = msg.diff || msg.error || '';
                if (currentProblem === msg.problem) updateCases();
                if (currentCase === msg.testcase && currentProblem === msg.problem) updateMatch();
                break;
              case 'submit_result':
                msg.passed.forEach((p, i) => {
                  passed[msg.problem][i] = p;
                  diffs[msg.problem][i] = msg.diffs[i];
                });
                if (currentProblem === msg.problem) {
                  updateCases();
                  updateMatch();
                }
                // Could display scores somewhere, but for now, just update cases
                break;
              case 'leaderboard':
                populateLeaderboard(msg.data);
                break;
              case 'error':
                alert(msg.msg);
                break;
            }
          };

          applyBtn.onclick = () => {
            const n = nameInput.value.trim();
            const l = langSelect.value;
            if (!n) return alert('Enter name');
            ws.send(JSON.stringify({ type: 'apply', name: n, lang: l }));
            applyBtn.textContent = 'Waiting...';
            applyBtn.disabled = true;
          };

          testBtn.onclick = () => {
            if (phase !== 'ongoing' || !accepted) return;
            ws.send(JSON.stringify({ type: 'test', problem: currentProblem, case: currentCase, code: code.value, lang }));
          };

          submitBtn.onclick = () => {
            if (phase !== 'ongoing' || !accepted) return;
            ws.send(JSON.stringify({ type: 'submit', problem: currentProblem, code: code.value, lang }));
          };

          finishBtn.onclick = () => {
            wait.style.display = 'block';
            arenaElements.forEach(el => el.style.display = 'none');
          };

          goBackBtn.onclick = () => {
            wait.style.display = 'none';
            arenaElements.forEach(el => el.style.display = '');
          };

          code.addEventListener('input', () => {
            localStorage.setItem(\`code_\${currentProblem}\`, code.value);
          });

          // Init tabs
          challenges.forEach((ch, i) => {
            const btn = document.createElement('button');
            btn.textContent = ch.name;
            btn.onclick = () => selectProblem(i);
            tabs.appendChild(btn);
          });
          selectProblem(0);

          // Check reconnect
          if (name) {
            ws.onopen = () => ws.send(JSON.stringify({ type: 'reconnect', name }));
          } else {
            updateUI();
          }
        </script>
      </body>
    </html>
  `, {
    headers: { 'content-type': 'text/html' },
  });
});

handleCLI();