#!/usr/bin/env -S deno run -A --watch
/**
 * Coder's Arena (single-file)
 * - Host/Admin UI: http://<host-ip>/admin
 * - Participant UI: http://<host-ip>/
 *
 * WebSocket message protocol (JSON):
 * - Participant -> server:
 *   {type:'identify', role:'participant', name, language}
 *   {type:'apply'}  // when user clicks Apply
 *   {type:'submit', payload:{problemId, code, language, runType, caseIndex?}}
 *   {type:'finish'}
 *
 * - Admin -> server:
 *   {type:'identify', role:'admin', name}
 *   {type:'decision', applicantId, decision: 'accept'|'decline'}
 *   {type:'submission_result', participantId, submissionResult}
 *
 * - Server -> relevant sockets:
 *   {type:'new_application', applicant}
 *   {type:'application_result', applicantId, result:'accepted'|'declined'}
 *   {type:'submission', submissionObj}  // forwarded to admin
 *   {type:'submission_feedback', submissionResult} // forwarded to participant
 */

import { serve } from "https://deno.land/std@0.201.0/http/server.ts";

const PORT = 80; // change to 8000 if you prefer

// ---------- sample challenges (edit to taste) ----------
const challenges = [
  {
    id: "fizzbuzz",
    name: "FizzBuzz",
    html: "<p>Print numbers 1..N with Fizz/Buzz rules.</p>",
    testcases: [
      { id: 0, input: "5\n", expected: "1\n2\nFizz\n4\nBuzz\n", points: 10 },
      { id: 1, input: "15\n", expected: "1\n2\nFizz\n4\nBuzz\nFizz\n7\n8\nFizz\nBuzz\n11\nFizz\n13\n14\nFizzBuzz\n", points: 20 }
    ]
  },
  {
    id: "trail-zeros",
    name: "Trailing Zeros",
    html: "<p>Count trailing zeros in N!.</p>",
    testcases: [
      { id: 0, input: "5\n", expected: "1\n", points: 10 },
      { id: 1, input: "100\n", expected: "24\n", points: 20 }
    ]
  }
];
// -------------------------------------------------------

type WS = {
  socket: WebSocket;
  id: string;
  role?: "admin" | "participant";
  name?: string;
  language?: string;
  applicantId?: string; // for participants who applied
};

const sockets = new Map<string, WS>();
const applicants = new Map<string, { id: string; name: string; language: string; socketId: string; status: "pending" | "accepted" | "declined" }>();

function newId(prefix = "") {
  return prefix + crypto.randomUUID();
}

// serve HTML (both participant and admin page) with injected challenges
function pageHtml(pathname: string) {
  const challengesJson = JSON.stringify(challenges).replace(/</g, "\\u003c");
  return `<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Coder's Arena</title>
  <style>
    :focus {outline:none}
    html {height:100%}
    body {
        display: grid;
        height: 100%;
        grid-template: 25px 50px auto 25px / auto 20px auto 20px auto;
        margin: 0;
        padding: 5px;
        gap: 6px;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
        background: #111;
        color: #eee;
    }
    #div-l,#div-r { background:#222; }
    #title { grid-area:1/1/span 1/span 5; text-align:center; font-weight:700; }
    #tabs { display:flex; grid-area:2/1/span 1/span 5; gap:6px; }
    #tabs button { flex:1; padding:6px; border-radius:6px; border:0; background:#222; color:#fff; }
    #info { grid-area:3/1; padding:10px; background:#151515; border-radius:6px; }
    #code { grid-area:3/3; font:14px/1.2 "Courier New", monospace; border-radius:6px; padding:8px; background:#0b0b0b; color:#bfbfbf; width:100%; height: 60vh; box-sizing:border-box; }
    #result { display:grid; grid-template: 40px auto 40px; grid-area:3/5; gap:8px; padding:8px; background:#151515; border-radius:6px; align-items:start; }
    #cases button { margin-right:6px; }
    #time { grid-area:4/1/span 1/span 5; text-align:center; padding:8px; background:#0f0f0f; border-radius:6px; }
    #home, #wait, #over { grid-area:2/1/span 2/span 5; background:rgba(255,255,255,0.03); padding:12px; border-radius:8px; display:none;}
    #home.show, #wait.show, #over.show { display:block; }
    .admin-panel { padding:8px; background:#0f0f0f; border-radius:6px; color:#fff; height:80vh; overflow:auto; }
    .app-row { display:flex; gap:8px; align-items:center; margin-bottom:6px; }
    .app-row button { padding:6px; border-radius:6px; border:0; }
    .ok { background: #155724; color:#d4ffd9; }
    .bad { background: #721c24; color:#ffd6d6; }
    .muted { opacity:0.7; font-size:0.9rem }
    /* light styling for admin UI when on /admin */
    ${pathname === "/admin" ? `
      body { background:#070707; }
    ` : ""}
  </style>
</head>
<body>
  <div id="title">Coder's Arena</div>

  <div id="tabs" style="display:none"></div>

  <div id="info"><strong>Problem</strong><div id="problem-html"></div></div>

  <textarea id="code" spellcheck="false" autocorrect="off" autocapitalize="off" autocomplete="off"></textarea>

  <div id="result">
    <div id="cases">
      <!-- testcase buttons built dynamically -->
    </div>
    <div id="match" style="white-space:pre-wrap; background:#080808; padding:8px; border-radius:6px; min-height:120px;">
      Output / diffs appear here
    </div>
    <div id="action">
      <button id="testBtn">Test</button>
      <button id="submitBtn">Submit</button>
      <button id="finishBtn">Finish</button>
    </div>
  </div>

  <div id="time">Waiting for competition</div>

  <div id="home" class="show">
    <h1>Welcome to Coder's Arena 2025!</h1>
    <p>Enter Name:</p>
    <input id="nameInput" name="name">
    <p>Select Language:</p>
    <select id="langSelect" name="language">
      <option>Python</option>
      <option>Java</option>
      <option>C++</option>
      <option>C</option>
      <option>JavaScript</option>
    </select>
    <button id="applyBtn">Apply!</button>
    <p id="applyStatus" class="muted"></p>
  </div>

  <div id="wait">
    <h1>You submitted, wait for competition to end</h1>
    <button id="goBackBtn">Go back</button>
  </div>

  <div id="over">
    <h1>The Coder's Arena is finished!</h1>
    <p>Here are the winners!</p>
    <!-- leaderboards to be filled by admin later -->
  </div>

  <!-- Admin area (only visible when admin identifies) -->
  <div id="adminArea" style="grid-area:3/3; display:none;">
    <div class="admin-panel">
      <h3>Admin Panel</h3>
      <div id="applicants"></div>
      <hr />
      <div id="incomingSubmissions"><strong>Incoming submissions</strong></div>
      <hr />
      <div id="adminLog"></div>
    </div>
  </div>

  <script>
    // injected data from server:
    window.__CHALLENGES__ = ${challengesJson};

    // UI logic
    const wsProto = (location.protocol === "https:") ? "wss" : "ws";
    const ws = new WebSocket(wsProto + "://" + location.host + "/ws");
    let mySocketId = null;
    let myRole = null;
    let myName = null;
    let myLanguage = null;
    let currentProblem = window.__CHALLENGES__[0] || null;
    const tabsEl = document.getElementById("tabs");
    const problemHtml = document.getElementById("problem-html");
    const casesEl = document.getElementById("cases");
    const matchEl = document.getElementById("match");
    const codeEl = document.getElementById("code");
    const homeEl = document.getElementById("home");
    const adminArea = document.getElementById("adminArea");
    const applyBtn = document.getElementById("applyBtn");
    const applyStatus = document.getElementById("applyStatus");
    const nameInput = document.getElementById("nameInput");
    const langSelect = document.getElementById("langSelect");
    const testBtn = document.getElementById("testBtn");
    const submitBtn = document.getElementById("submitBtn");
    const finishBtn = document.getElementById("finishBtn");
    const goBackBtn = document.getElementById("goBackBtn");

    function renderTabs() {
      tabsEl.innerHTML = "";
      window.__CHALLENGES__.forEach((c, idx) => {
        const b = document.createElement("button");
        b.textContent = c.name;
        b.onclick = () => {
          currentProblem = c;
          renderProblem();
        };
        tabsEl.appendChild(b);
      });
      tabsEl.style.display = window.__CHALLENGES__.length ? "flex" : "none";
    }
    function renderProblem() {
      problemHtml.innerHTML = currentProblem.html;
      // build testcase buttons
      casesEl.innerHTML = "";
      (currentProblem.testcases || []).forEach(tc => {
        const btn = document.createElement("button");
        btn.textContent = String(tc.id).padStart(2, "0");
        btn.onclick = () => {
          matchEl.textContent = "Testcase " + tc.id + "\\nInput:\\n" + tc.input + "\\nExpected:\\n" + tc.expected;
        }
        casesEl.appendChild(btn);
      });
    }

    ws.addEventListener("open", () => {
      console.log("ws open");
      // If we loaded the admin path, auto-identify as admin (you can still change name)
      if (location.pathname === "/admin") {
        myRole = "admin";
        myName = "Host";
        ws.send(JSON.stringify({type:"identify", role:"admin", name: myName}));
        adminArea.style.display = "block";
        homeEl.style.display = "none";
      } else {
        // participant default
        adminArea.style.display = "none";
      }
      renderTabs();
      renderProblem();
    });

    ws.addEventListener("message", (ev) => {
      try {
        const msg = JSON.parse(ev.data);
        handleServerMessage(msg);
      } catch (e) {
        console.warn("non-json ws message", ev.data);
      }
    });

    function handleServerMessage(msg) {
      switch (msg.type) {
        case "identified":
          mySocketId = msg.socketId;
          console.log("identified as", msg.socketId);
          break;
        case "new_application":
          addApplicantRow(msg.applicant);
          break;
        case "application_result":
          if (msg.result === "accepted") {
            applyStatus.textContent = "Accepted — competition will start soon.";
            homeEl.classList.remove("show");
            // reveal arena
            document.getElementById("tabs").style.display = "flex";
            document.getElementById("result").style.display = "grid";
            document.getElementById("info").style.display = "block";
          } else {
            applyStatus.textContent = "Declined by host.";
          }
          break;
        case "submission":
          // admin receives forwarded submission
          adminLog("Submission received: " + JSON.stringify(msg.submission, null, 2));
          addSubmissionRow(msg.submission);
          break;
        case "submission_feedback":
          // participant receives test results
          matchEl.textContent = msg.feedbackText || JSON.stringify(msg, null, 2);
          break;
        case "log":
          adminLog(msg.message);
          break;
      }
    }

    // --- participant UI events ---
    applyBtn.onclick = () => {
      const name = nameInput.value.trim();
      const lang = langSelect.value;
      if (!name) { applyStatus.textContent = "Please enter a name"; return; }
      myRole = "participant";
      myName = name;
      myLanguage = lang;
      ws.send(JSON.stringify({type:"identify", role:"participant", name, language:lang}));
      ws.send(JSON.stringify({type:"apply"}));
      applyStatus.textContent = "Applied — waiting for host...";
    };

    testBtn.onclick = () => {
      // test current testcase 0 (for demo)
      const code = codeEl.value;
      ws.send(JSON.stringify({type:"submit", payload:{problemId: currentProblem.id, code, language: myLanguage || langSelect.value, runType: "test", caseIndex: 0}}));
      matchEl.textContent = "Sent test request to host...";
    };
    submitBtn.onclick = () => {
      const code = codeEl.value;
      ws.send(JSON.stringify({type:"submit", payload:{problemId: currentProblem.id, code, language: myLanguage || langSelect.value, runType: "submit"}}));
      matchEl.textContent = "Sent full submission to host...";
    };
    finishBtn.onclick = () => {
      ws.send(JSON.stringify({type:"finish"}));
      homeEl.classList.add("show");
    };

    goBackBtn.onclick = () => {
      document.getElementById("wait").classList.remove("show");
    };

    // --- admin helpers ---
    const applicantsDiv = document.getElementById("applicants");
    function addApplicantRow(a) {
      const row = document.createElement("div");
      row.className = "app-row";
      row.id = "app-" + a.id;
      row.innerHTML = "<div><strong>" + a.name + "</strong> (" + a.language + ")</div>";
      const accept = document.createElement("button");
      accept.textContent = "Accept";
      accept.className = "ok";
      accept.onclick = () => {
        ws.send(JSON.stringify({type:"decision", applicantId: a.id, decision: "accept"}));
        row.querySelectorAll("button").forEach(b=>b.disabled=true);
      };
      const decline = document.createElement("button");
      decline.textContent = "Decline";
      decline.className = "bad";
      decline.onclick = () => {
        ws.send(JSON.stringify({type:"decision", applicantId: a.id, decision: "decline"}));
        row.querySelectorAll("button").forEach(b=>b.disabled=true);
      };
      row.appendChild(accept);
      row.appendChild(decline);
      applicantsDiv.appendChild(row);
    }

    const incomingSub = document.getElementById("incomingSubmissions");
    function addSubmissionRow(sub) {
      const div = document.createElement("div");
      div.className = "app-row";
      div.style.flexDirection = "column";
      const meta = document.createElement("div");
      meta.textContent = (sub.participantName || sub.participantId) + " -> " + sub.problemId + " (" + sub.runType + ")";
      const pre = document.createElement("pre");
      pre.style.maxWidth = "100%";
      pre.style.whiteSpace = "pre-wrap";
      pre.textContent = sub.code.slice(0, 1000);
      const btnRow = document.createElement("div");
      const runManually = document.createElement("button");
      runManually.textContent = "Mark OK (simulate pass)";
      runManually.onclick = () => {
        // admin can send result back to participant
        const feedback = { participantId: sub.participantId, ok: true, details: "Simulated OK (admin marked pass)" };
        ws.send(JSON.stringify({type:"submission_result", participantId: sub.participantId, submissionResult: feedback}));
        div.remove();
      };
      const sendFail = document.createElement("button");
      sendFail.textContent = "Mark Fail";
      sendFail.className = "bad";
      sendFail.onclick = () => {
        const feedback = { participantId: sub.participantId, ok: false, details: "Simulated Fail (admin marked fail)", diff: "expected X but got Y" };
        ws.send(JSON.stringify({type:"submission_result", participantId: sub.participantId, submissionResult: feedback}));
        div.remove();
      };
      btnRow.appendChild(runManually);
      btnRow.appendChild(sendFail);
      div.appendChild(meta);
      div.appendChild(pre);
      div.appendChild(btnRow);
      incomingSub.appendChild(div);
    }

    function adminLog(txt) {
      const l = document.getElementById("adminLog");
      const p = document.createElement("div");
      p.textContent = "[" + new Date().toLocaleTimeString() + "] " + txt;
      l.prepend(p);
    }

    // allow admin to identify if not auto
    if (location.pathname === "/admin") {
      // small form to set admin name can be added; for simplicity we auto-identify as admin on open above.
    }
  </script>
</body>
</html>`;
}

// ---------- WebSocket + server state ----------
serve(async (req) => {
  const url = new URL(req.url);

  // serve static HTML pages for participant and admin
  if (req.method === "GET" && (url.pathname === "/" || url.pathname === "/admin")) {
    return new Response(pageHtml(url.pathname), { status: 200, headers: { "content-type": "text/html; charset=utf-8" } });
  }

  // websocket endpoint
  if (url.pathname === "/ws" && req.headers.get("upgrade")?.toLowerCase() === "websocket") {
    const { socket, response } = Deno.upgradeWebSocket(req);
    const socketId = newId("s-");
    const wsObj: WS = { socket, id: socketId };
    sockets.set(socketId, wsObj);

    socket.onopen = () => {
      // send identification ack
      try { socket.send(JSON.stringify({ type: "identified", socketId })); } catch {}
      console.log("ws open", socketId);
    };

    socket.onmessage = (e) => {
      try {
        const msg = typeof e.data === "string" ? JSON.parse(e.data) : null;
        if (!msg || !msg.type) return;
        handleMessage(wsObj, msg);
      } catch (err) {
        console.error("ws message error", err);
      }
    };

    socket.onclose = () => {
      console.log("ws closed", socketId);
      // remove from apps if present
      for (const [id, a] of applicants.entries()) {
        if (a.socketId === socketId) applicants.delete(id);
      }
      sockets.delete(socketId);
    };

    socket.onerror = (ev) => {
      console.error("ws error", ev);
    };

    return response;
  }

  // fallback: 404
  return new Response("Not found", { status: 404 });
}, { port: PORT });

console.log(`Coder's Arena server running on :${PORT}`);
console.log(`Open / to join as participant, /admin to manage (use host machine browser).`);

// ---------- message handling ----------
async function handleMessage(wsObj: WS, msg: any) {
  const socket = wsObj.socket;
  switch (msg.type) {
    case "identify":
      wsObj.role = msg.role;
      wsObj.name = msg.name;
      wsObj.language = msg.language;
      console.log(`identify: ${wsObj.id} role=${wsObj.role} name=${wsObj.name}`);
      // no sensitive info here; ack
      try { socket.send(JSON.stringify({ type: "identified", socketId: wsObj.id })); } catch {}
      break;

    case "apply":
      // participant wants to join
      if (wsObj.role !== "participant") {
        try { socket.send(JSON.stringify({ type: "log", message: "You must identify as participant before applying." })); } catch {}
        return;
      }
      const applicantId = newId("a-");
      applicants.set(applicantId, { id: applicantId, name: wsObj.name || "unknown", language: wsObj.language || "unknown", socketId: wsObj.id, status: "pending" });
      // notify all admins
      broadcastToAdmins({ type: "new_application", applicant: { id: applicantId, name: wsObj.name, language: wsObj.language } });
      try { socket.send(JSON.stringify({ type: "log", message: "Applied to host." })); } catch {}
      break;

    case "decision":
      // admin accepted/declined
      if (wsObj.role !== "admin") {
        try { socket.send(JSON.stringify({ type: "log", message: "Only admins can make decisions." })); } catch {}
        return;
      }
      {
        const { applicantId, decision } = msg;
        const a = applicants.get(applicantId);
        if (!a) {
          try { socket.send(JSON.stringify({ type: "log", message: "Applicant not found." })); } catch {}
          return;
        }
        a.status = (decision === "accept") ? "accepted" : "declined";
        // notify the participant socket
        const participantWs = sockets.get(a.socketId);
        if (participantWs) {
          try {
            participantWs.socket.send(JSON.stringify({ type: "application_result", applicantId, result: a.status === "accepted" ? "accepted" : "declined" }));
          } catch {}
        }
        // notify all admins about the decision (update UI)
        broadcastToAdmins({ type: "log", message: `Applicant ${a.name} ${decision}ed by admin ${wsObj.name || wsObj.id}` });
      }
      break;

    case "submit":
      // a participant submitted code; forward to admins for running
      if (!wsObj.role || wsObj.role !== "participant") {
        try { socket.send(JSON.stringify({ type: "log", message: "Must be participant to submit." })) } catch {}
        return;
      }
      {
        const payload = msg.payload;
        const submission = {
          id: newId("sub-"),
          participantId: wsObj.id,
          participantName: wsObj.name,
          timestamp: Date.now(),
          problemId: payload.problemId,
          code: payload.code,
          language: payload.language,
          runType: payload.runType,
          caseIndex: payload.caseIndex ?? null
        };
        // forward to admins
        broadcastToAdmins({ type: "submission", submission });
        // ack participant
        try { socket.send(JSON.stringify({ type: "log", message: "Submission forwarded to host/admin for judging." })) } catch {}
      }
      break;

    case "submission_result":
      // admin returns a result for a particular participant
      if (wsObj.role !== "admin") {
        try { socket.send(JSON.stringify({ type: "log", message: "Only admin can send submission results." })) } catch {}
        return;
      }
      {
        const { participantId, submissionResult } = msg;
        // find participant socket by socket id
        const target = [...sockets.values()].find(s => s.id === participantId);
        if (target) {
          try {
            target.socket.send(JSON.stringify({ type: "submission_feedback", feedbackText: JSON.stringify(submissionResult, null, 2), result: submissionResult }));
          } catch {}
        }
      }
      break;

    case "finish":
      // participant finished; admin can decide what to do in UI
      wsObj.socket.send(JSON.stringify({ type: "log", message: "Finish received (client) — admin will finalize scoreboard." }));
      break;

    default:
      try { socket.send(JSON.stringify({ type: "log", message: "Unknown message type: " + msg.type })); } catch {}
  }
}

function broadcastToAdmins(obj: any) {
  for (const s of sockets.values()) {
    if (s.role === "admin") {
      try { s.socket.send(JSON.stringify(obj)); } catch (e) { console.error("send admin err", e); }
    }
  }
}
