#!/usr/bin/env -S deno run -A --watch
import { TextLineStream } from "https://deno.land/std@0.224.0/streams/text_line_stream.ts";

// #region Configurations - Developer can modify
/** Unit of the interface in Pixels */
const unit = 50;
/** Challenges */
const challenges:{
    /** Name of challenge */
    name:string,
    /** Problem statement */
    info:string,
    /** Testcases */
    test:{
        /** Points */
        points:number,
        /** Input */
        input:string,
        /** Output */
        output:string
    }[]
}[] = [
  {
    name: "FizzBuzz",
    info: `<p>Write a program that reads an integer n from standard input and prints the numbers from 1 to n, each on a new line. For multiples of 3, print "Fizz" instead of the number. For multiples of 5, print "Buzz". For numbers that are multiples of both 3 and 5, print "FizzBuzz".</p>`,
    test: [
      { input: "5\n", output: "1\n2\nFizz\n4\nBuzz", points: 10 },
      { input: "15\n", output: "1\n2\nFizz\n4\nBuzz\nFizz\n7\n8\nFizz\nBuzz\n11\nFizz\n13\n14\nFizzBuzz", points: 20 },
      { input: "1\n", output: "1", points: 5 },
      { input: "30\n", output: "1\n2\nFizz\n4\nBuzz\nFizz\n7\n8\nFizz\nBuzz\n11\nFizz\n13\n14\nFizzBuzz\n16\n17\nFizz\n19\nBuzz\nFizz\n22\n23\nFizz\nBuzz\n26\nFizz\n28\n29\nFizzBuzz", points: 30 },
    ],
  },
];
// #endregion
// #region System variables - Modifed on runtime
/** Current phase of competition */
let phase:'start'|'ongoing'|'ended' = 'start';
/** Starting date of competition */
let time_start:null|Date = null;
/** Ending date of competition */
let time_end:null|Date = null;
/** Total possible points */
const total_points:number = challenges.reduce((sum, ch) => sum + ch.test.reduce((s, tc) => s + tc.points, 0), 0);
/** Participants */
const participants:Map<string,{
    /** Name of participant */
    name:string,
    /** Langauge of participant */
    lang:string,
    /** Is accepted? */
    accepted:boolean,

    problemScores: {
        maxScore: number;
        currentScore: number;
        achieveTime: Date | null;
    }[];
    totalMax: number;
    totalCurrent: number;
    totalAchieveTime: Date | null;
}> = new Map();
/** Websocket to participant */
const connections:Map<WebSocket, string> = new Map();
/** Pending participant applications */
const pending:{ name: string; lang: string; ws: WebSocket }[] = [];
// #endregion
// #region Action - Functions
async function cli_input() {
  /** Admin commands */
  const lines = Deno.stdin.readable
    .pipeThrough(new TextDecoderStream())
    .pipeThrough(new TextLineStream());
  for await (const line of lines) {
    const command = line.trim().toLowerCase();
    if (pending.length) {
        /** Current pending applicant */
        const current = pending.shift()!;
        if (command === 'y') {
            /** Name already exists */
            if (participants.has(current.name))
                current.ws.send(JSON.stringify({ type: 'declined', msg: 'Name already taken' }));
            /** Record participant */
            else {
                participants.set(current.name, {
                    name: current.name,
                    lang: current.lang,
                    accepted: true,
                    problemScores: challenges.map(() => ({ maxScore: 0, currentScore: 0, achieveTime: null })),
                    totalMax: 0,
                    totalCurrent: 0,
                    totalAchieveTime: null,
                });
                connections.set(current.ws, current.name);
                current.ws.send(JSON.stringify({ type: 'accepted' }));
            }
        }
    }
  }
}
// #endregion

Deno.serve({port:80}, (req:Request) => {
    const u = unit;
    return new Response(/*html*/`
        <!DOCTYPE html>
        <html>
            <head>
                <title>Coder's Arena</title>
                <style>
                    :focus {outline:none}
                    html {height:100%}
                    body {
                        display: grid;
                        height: calc(100% - ${0.2*u}px);
                        grid-template: ${0.5*u}px ${u}px auto ${0.5*u}px / auto ${0.2*u}px auto ${0.2*u}px auto;
                        margin: 0;
                        padding: ${0.1*u}px;
                    }
                    #div-l {grid-area:3/2}
                    #div-r {grid-area:3/4}
                    #div-l,#div-r {
                        background-color: #222;
                    }
                    #title {
                        grid-area:1/1/span 1/span 5;
                        text-align: center;
                    }
                    #tabs {
                        display: flex;
                        grid-area:2/1/span 1/span 5;
                    }
                    #tabs button {
                        flex-grow: 1;
                    }
                    #info {
                        grid-area:3/1;
                    }
                    #code {
                        grid-area:3/3;
                        font: ${0.3*u}px Courier;
                        border: 0;
                    }
                    #result {
                        display: grid;
                        grid-template: ${u}px auto ${u}px;
                        grid-area:3/5;
                    }
                    #time {
                        grid-area:4/1/span 1/span 5;
                        text-align: center;
                    }
                    #home, #over, #wait {
                        grid-area: 2/1/span 2/span 5;
                    }
                </style>
            </head>
            <body>
                <!-- Title -->
                <div id="title">Coder's Arena</div>
                <!-- Draggable vertical markers -->
                <div id="div-l"></div>
                <div id="div-r"></div>
                <!-- Problems -->
                <div id="tabs">
                    <button>FizzBuzz</button>
                    <button>Trailling Zeros</button>
                    <button>Digital Root</button>
                    <button>Diamond Elegance</button>
                    <button>Roman Numeral</button>
                </div>
                <!-- Problem Statement -->
                <div id="info">
                    <div>Problem Statement</div>
                </div>
                <!-- Code -->
                <textarea id="code" spellcheck="false" autocorrect="off" autocapitalize="off" autocomplete="off"></textarea>
                <!-- Running -->
                <div id="result">
                    <div id="cases">
                        <button>00</button>
                        <button>01</button>
                        <button>02</button>
                        <button>03</button>
                    </div>
                    <div id="match">
                        Enter inte<span>r</span>ger: 5<br>
                    </div>
                    <div id="action">
                        <button>Test</button>
                        <button>Submit</button>
                        <button>Finish</button>
                    </div>
                </div>
                <!-- Time limit -->
                <div id="time">
                    01:20:45 left
                </div>
                <!-- Registering -->
                <div id="home">
                    <h1>Welcome to Coder's Arena 2025!</h1>
                    <p>Enter Name:</p>
                    <input name="name"></input>
                    <p>Select Language:</p>
                    <select name="language">
                        <option>Python</option>
                        <option>Java</option>
                        <option>C++</option>
                        <option>C</option>
                    </select>
                    <button>Apply!</button>
                    <!-- If already applied -->
                    <p>Okay your registered! Wait for the competition to start</p>
                </div>
                <!-- Waiting -->
                <div id="wait">
                    <h1>You submited, wait for competition to end</h1>
                    <button>Go back</button>
                </div>
                <!-- Over -->
                <div id="over">
                    <h1>The Coder's Area is finished!</h1>
                    <p>Here are the winners!</p>
                    <h3>Python</h3>
                    <table>
                        <tr><th>Name</th><th>Points</th></tr>
                    </table>
                    <h3>Java</h3>
                    <table>
                        <tr><th>Name</th><th>Points</th></tr>
                    </table>
                    <h3>C</h3>
                    <table>
                        <tr><th>Name</th><th>Points</th></tr>
                    </table>
                    <h3>C++</h3>
                    <table>
                        <tr><th>Name</th><th>Points</th></tr>
                    </table>
                </div>
            </body>
        </html>
    `, {
        headers: {'content-type':'html'}
    });
})